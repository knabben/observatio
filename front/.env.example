# Dev-only overrides for running `pnpm run dev` (frontend on :3000) against a
# separately-running backend (:8080). Leave unset for `make build` / `make verify-binary`
# and the embedded production binary — it addresses the API/WS same-origin by default.
# See specs/003-screen-ui-refactor/contracts/environment-config.md

# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/watcher
# NEXT_PUBLIC_WS_URL_CHATBOT=ws://localhost:8080/ws/analysis
